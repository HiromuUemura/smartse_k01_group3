# Google OAuth client information
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match the Authorized redirect URI in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Usually "primary" for the signed-in Google account.
# You can also specify a specific calendar ID.
GOOGLE_CALENDAR_ID=primary

# Optional comma-separated attendee emails used when the AI decides a schedule is for parents only.
PARENT_ATTENDEES=father@example.com, mother@example.com

# Optional comma-separated attendee emails used when the AI decides a schedule is for the whole family.
FAMILY_ATTENDEES=father@example.com, mother@example.com, child@example.com

# OpenAI (プリント画像からの予定抽出に使用)
# 画面(GUI)からAPIキーを入力すると httpOnly Cookie に保存され、こちらより優先されます。
# サーバ既定値として置きたい場合のみ設定してください。
OPENAI_API_KEY=
# 使用モデル。要グループ確認: gpt-5-nano / gpt-5-mini の正式IDをOpenAIドキュメントで確認。
OPENAI_MODEL=gpt-5-nano

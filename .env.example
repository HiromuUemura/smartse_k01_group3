# Google OAuth client information
# Create an OAuth client as "Web application" in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match the Authorized redirect URI in Google Cloud Console.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Usually "primary" for the signed-in Google account.
# You can also specify a specific calendar ID.
GOOGLE_CALENDAR_ID=primary

# Optional comma-separated attendee emails for test family sharing.
# Example: FAMILY_ATTENDEES=father@example.com,child@example.com
FAMILY_ATTENDEES=
